{
  "title": "Flask App — Live Infrastructure Overview",
  "uid": "app-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "2s",
  "panels": [
    {
      "id": 0,
      "title": "",
      "type": "text",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 2 },
      "options": {
        "mode": "markdown",
        "content": "## MLH PE Hack — Live Infrastructure Overview"
      }
    },
    {
      "id": 10,
      "title": "App Status",
      "description": "Live health of the Flask app. Turns RED immediately when Prometheus can no longer scrape /metrics — app is down.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 2, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP",   "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"flask-app\"}",
          "legendFormat": "App"
        }
      ]
    },
    {
      "id": 11,
      "title": "Request Rate (now)",
      "description": "Current requests per second on production endpoints (excludes /metrics, /stress, /test-error).",
      "type": "stat",
      "gridPos": { "x": 6, "y": 2, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{endpoint!~\"/metrics|/test-error|/stress\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 8,
      "title": "Latency p95 (now)",
      "description": "Current 95th percentile request latency. Green < 100ms, yellow < 500ms, red above.",
      "type": "stat",
      "gridPos": { "x": 12, "y": 2, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red",    "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 9,
      "title": "Error Rate % (now)",
      "description": "Current percentage of requests returning 5xx errors over a 1-minute window.",
      "type": "stat",
      "gridPos": { "x": 18, "y": 2, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto",
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_requests_total{http_status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "id": 20,
      "title": "Saturation — CPU & Memory",
      "type": "row",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "CPU Usage % (now)",
      "description": "System-wide CPU usage. Yellow at 60%, red at 85%.",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 9, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red",    "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "app_cpu_usage_percent",
          "legendFormat": "CPU",
          "interval": "2s"
        }
      ]
    },
    {
      "id": 2,
      "title": "RAM Usage (now)",
      "description": "Flask process RSS memory. Yellow at 256MB, red at 512MB.",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 9, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 256 },
              { "color": "red",    "value": 512 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "app_ram_usage_mb",
          "legendFormat": "RAM"
        }
      ]
    },
    {
      "id": 3,
      "title": "CPU Usage Over Time",
      "description": "Historical CPU. Spikes here correlate with high latency.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "app_cpu_usage_percent",
          "legendFormat": "CPU %",
          "interval": "2s"
        }
      ]
    },
    {
      "id": 4,
      "title": "RAM Usage Over Time",
      "description": "Gradual growth = memory leak. Sudden drop = process restart.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "min": 0 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "app_ram_usage_mb",
          "legendFormat": "RAM MB"
        }
      ]
    },
    {
      "id": 21,
      "title": "Traffic & Errors",
      "type": "row",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "Traffic — Requests/sec by Endpoint",
      "description": "Production endpoint request rates. Drops to zero = downtime.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "min": 0 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{endpoint!~\"/test-error|/stress|/metrics\"}[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "interval": "5s"
        }
      ]
    },
    {
      "id": 6,
      "title": "Error Rate — 5xx %",
      "description": "Above 1% = investigate. Above 10% = HighErrorRate alert fires.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red",    "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * sum(rate(http_requests_total{http_status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "5xx %",
          "interval": "5s"
        }
      ]
    },
    {
      "id": 22,
      "title": "Latency",
      "type": "row",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Latency — p50 / p95 / p99",
      "description": "p95 > 500ms = warning. p95 > 1s = critical. Spikes here with CPU spikes = saturation-driven slowdown.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "min": 0 }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "interval": "5s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "interval": "5s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "interval": "5s"
        }
      ]
    }
  ]
}
